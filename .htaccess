# ANTIQUA BARBAE - Configurazione Apache

# Impedisci la visualizzazione delle directory
Options -Indexes

# Pagina di errore personalizzata (opzionale)
# ErrorDocument 404 /404.php

# Proteggi file sensibili
<FilesMatch "(config\.php|\.htaccess|\.git)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Abilita rewrite engine per URL puliti (opzionale)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /antiqua-barbae/
    
    # Forza HTTPS (scommentare in produzione)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>

# Compressione GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json
</IfModule>

# Cache del browser
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Protezione XSS e Clickjacking
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>